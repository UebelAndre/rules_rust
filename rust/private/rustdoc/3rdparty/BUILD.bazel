load("@rules_rust//crate_universe:defs.bzl", "crate", "crates_vendor")

crates_vendor(
    name = "crates_vendor",
    mode = "remote",
    packages = {
        "zip": crate.spec(
            default_features = False,
            version = "2",
        ),
    },
    # Short for 'rules_rust_rustdoc'. Keep this short to reduce
    # the risk to bump into absolute path length issues on Windows.
    repository_name = "rrrd",
    tags = ["manual"],
    vendor_path = "crates",
)
